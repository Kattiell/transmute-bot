{
  "buildCommand": "",
  "outputDirectory": ".",
  "framework": null,
  "functions": {
    "api/webhook.ts": {
      "maxDuration": 300
    },
    "api/set-webhook.ts": {
      "maxDuration": 10
    },
    "api/cron-cleanup.ts": {
      "maxDuration": 60
    },
    "api/cron-update-ath.ts": {
      "maxDuration": 120
    },
    "api/internal/arena/send.ts": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/internal/arena/send", "destination": "/api/internal/arena/send" }
  ],
  "crons": [
    {
      "path": "/api/cron-cleanup",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron-update-ath",
      "schedule": "*/30 * * * *"
    }
  ]
}
